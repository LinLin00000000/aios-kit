# Public example for the AIOS Mihomo Builder template.
# Copy to secrets/.env in the deployed Mihomo directory and fill real URLs there.
# Never commit secrets/.env.

# Fast path: one airport subscription URL.
MIHOMO_SUB_URL=
MIHOMO_SUB_ID=airport

# Multi-provider path. If any MIHOMO_PROVIDER_<N>_URL is set, numbered providers
# become the source of truth and MIHOMO_SUB_URL is ignored.
# Number order is fallback priority: 1 before 2 before 3.
# MIHOMO_PROVIDER_1_ID=zjk
# MIHOMO_PROVIDER_1_URL=
# MIHOMO_PROVIDER_1_ROLE=primary
# MIHOMO_PROVIDER_2_ID=bywave
# MIHOMO_PROVIDER_2_URL=
# MIHOMO_PROVIDER_2_ROLE=paid_backup

# Optional provider filters. These are regex strings understood by Mihomo proxy-provider.
# General filters affect PROXY groups; AI filters affect separate <id>-ai providers.
# MIHOMO_PROVIDER_1_FILTER=
# MIHOMO_PROVIDER_1_EXCLUDE_FILTER=
# MIHOMO_PROVIDER_1_AI_FILTER=
# MIHOMO_PROVIDER_1_AI_EXCLUDE_FILTER=

# Optional global AI provider filters applied when per-provider AI filters are empty.
# Example only; tune for your provider naming convention and target sites.
# MIHOMO_AI_EXCLUDE_FILTER=(?i)(Hong Kong|HK|Russia|RU)
MIHOMO_AI_FILTER=
MIHOMO_AI_EXCLUDE_FILTER=
