# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Local runtime/state/logs
/state/**
!/state/README.md
!/state/.gitkeep
/logs/**
!/logs/README.md
!/logs/.gitkeep
*.log

